# Same Supabase project as apps/pousali — copy URL/key from apps/pousali/.env.local
# (pousali uses SUPABASE_URL / SUPABASE_ANON_KEY; use the same values here as NEXT_PUBLIC_*)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gemini (used in later CMS phases; same key pattern as apps/pousali)
GEMINI_API_KEY=

# Legacy JWT (optional; SQLite admin seed scripts only — not used for Supabase auth)
# ADSGUPTA_JWT_SECRET=
