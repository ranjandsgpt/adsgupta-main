{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "paths": {
      "@adsgupta/amazon-audit": ["../../packages/amazon-audit/src/index.ts"],
      "@adsgupta/amazon-audit/*": ["../../packages/amazon-audit/src/*"],
      "@adsgupta/auth": ["../../packages/auth/src/index.ts"],
      "@adsgupta/auth/*": ["../../packages/auth/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/auth/src/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
