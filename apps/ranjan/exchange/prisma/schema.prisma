// OpenRTB Exchange — persistent storage for auctions, bids, events, publishers, DSP partners.
// Run: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Publisher {
  id                  String    @id @default(uuid())
  name                String?
  domain              String    @unique
  apiKey              String?   // hashed in production
  floorPrices         Json      @default("{}") // map of "300x250" -> 0.5
  blockedCategories   String[]  @default([])
  blockedAdvertisers  String[]  @default([])
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  auctions            Auction[]
}

model DspPartner {
  id              String    @id @default(uuid())
  name            String
  dspId           String    @unique // e.g. "openx", "test_bidder"
  endpoint        String
  authConfig      Json?     // encrypted API keys
  timeoutMs       Int       @default(120)
  maxQps          Int?
  enabledFormats  String[]  @default(["banner"])
  enabledSizes    Json      @default("[]")
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  bids            Bid[]
}

model Auction {
  id            String    @id // auction ID (UUID from exchange)
  publisherId   String?
  publisher     Publisher? @relation(fields: [publisherId], references: [id])
  pageUrl       String?
  timestamp     DateTime  @default(now())
  requestCount  Int       @default(0)
  fillCount     Int       @default(0)
  totalRevenue  Decimal   @default(0) @db.Decimal(12, 6)
  latencyMs     Int?
  deviceType    String?
  country       String?
  createdAt     DateTime  @default(now())
  bids          Bid[]
  events        Event[]

  @@index([publisherId, timestamp])
  @@index([timestamp])
}

enum BidStatus {
  won
  lost
  invalid
  below_floor
  timeout
}

model Bid {
  id               String     @id @default(uuid())
  auctionId        String
  auction          Auction    @relation(fields: [auctionId], references: [id])
  impressionId     String
  dspPartnerId     String?
  dspPartner       DspPartner? @relation(fields: [dspPartnerId], references: [id])
  price            Decimal    @db.Decimal(12, 6)
  status           BidStatus
  invalidReason    String?
  creativeId       String?
  advertiserDomain String?
  responseTimeMs   Int?
  createdAt        DateTime   @default(now())

  @@index([auctionId, dspPartnerId])
  @@index([dspPartnerId, createdAt])
}

enum EventType {
  impression
  viewable
  click
}

model Event {
  id           String    @id @default(uuid())
  auctionId    String
  auction      Auction   @relation(fields: [auctionId], references: [id])
  impressionId String
  eventType    EventType
  timestamp    DateTime  @default(now())
  metadata     Json?

  @@index([auctionId, eventType])
  @@index([eventType, timestamp])
}
