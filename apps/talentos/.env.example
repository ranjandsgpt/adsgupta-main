# Vercel Postgres + Prisma
POSTGRES_URL=
POSTGRES_PRISMA_URL=

# Auth (JWT for /api/auth/*)
JWT_SECRET=generate-a-long-random-string

# Google Gemini (Vercel: Gemini_API_Key)
Gemini_API_Key=
# Optional override (default: gemini-1.5-flash)
# GEMINI_MODEL=gemini-1.5-flash
# Fallback LLM (used only if Gemini fails)
ANTHROPIC_API_KEY=
# Optional fallback model
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Adzuna job search (/api/jobs/search, /api/jobs/config)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Razorpay (orders, verify, webhook)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: Razorpay Dashboard → Webhooks → signing secret
RAZORPAY_WEBHOOK_SECRET=
