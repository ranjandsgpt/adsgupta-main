# MongoDB (native driver)
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net
DB_NAME=talentos_db

# Auth (JWT for /api/auth/*)
JWT_SECRET=generate-a-long-random-string

# OpenAI (replaces Emergent LLM integration)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Adzuna job search (/api/jobs/search, /api/jobs/config)
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Razorpay (orders, verify, webhook)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: Razorpay Dashboard → Webhooks → signing secret
RAZORPAY_WEBHOOK_SECRET=
